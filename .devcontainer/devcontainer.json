{
  "name": "Projeto Django + Next.js",
  // Imagem base com Python 3
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",

  // Instala o Node.js para rodar o Next.js e o Tailwind
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },

  // Portas padrão: 8000 (Django) e 3000 (Next.js)
  "forwardPorts": [8000, 3000],

  "portsAttributes": {
    "8000": {
      "label": "Django API",
      "onAutoForward": "silent"
    },
    "3000": {
      "label": "Next.js App",
      "onAutoForward": "openPreview"
    }
  },

  // Extensões para Python, Django, React e Tailwind
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "batisteo.vscode-django",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },

  "remoteUser": "vscode"
}